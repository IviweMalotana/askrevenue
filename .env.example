# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# --- Database --------------------------------------------------------------
# Full-privilege connection: migrations, seeding, and the app's own tables.
DATABASE_URL=postgresql+psycopg://askrevenue:askrevenue@localhost:5432/askrevenue

# Least-privilege connection used to execute user-generated SQL.
# In production this MUST be a distinct, SELECT-only role.
READONLY_DATABASE_URL=postgresql+psycopg://askrevenue_ro:askrevenue_ro@localhost:5432/askrevenue

# --- Kimi (Moonshot AI) / LLM ----------------------------------------------
# Leave blank to run the app in fallback mode (curated example questions only).
# When set, natural-language questions are translated to SQL by Kimi.
# Get a key at https://platform.moonshot.ai (international) or
# https://platform.moonshot.cn (China — change KIMI_BASE_URL accordingly).
KIMI_API_KEY=
KIMI_MODEL=kimi-k2-0905-preview
KIMI_BASE_URL=https://api.moonshot.ai/v1

# --- Query safety ----------------------------------------------------------
QUERY_ROW_LIMIT=1000
QUERY_TIMEOUT_MS=5000

# --- App -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# --- Frontend (web/.env.local) --------------------------------------------
# The browser talks to the API through this base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
